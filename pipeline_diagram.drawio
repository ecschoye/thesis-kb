        <!-- ── Frontend ── -->
        <mxCell id="frontend" value="&lt;b&gt;React 18 SPA&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:9px&quot;&gt;9 modes • Chat UI&lt;br&gt;Source cards • Feedback&lt;br&gt;Dark mode • Markdown&lt;br&gt;Tailwind + Babel&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontFamily=Inter;fontSize=12;arcSize=12;strokeWidth=2;" vertex="1" parent="query_container">
