        <!-- ── Step 5: Scoring & Boosting ── -->
        <mxCell id="scoring" value="&lt;b&gt;5. Score &amp;amp; Boost&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:9px&quot;&gt;• Thesis relevance&lt;br&gt;• Section-aware boost&lt;br&gt;• User feedback boost&lt;br&gt;• Depth-of-coverage&lt;br&gt;• Paper authority&lt;br&gt;&amp;nbsp; (citations, metadata)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontFamily=Inter;fontSize=12;arcSize=12;" vertex="1" parent="query_container">
          <mxGeometry x="860" y="80" width="150" height="140" as="geometry" />
        </mxCell>

        <!-- ── Step 6: Cross-Encoder Rerank ── -->
        <mxCell id="rerank" value="&lt;b&gt;6. Cross-Encoder&lt;br&gt;Rerank&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;flashrank&lt;br&gt;ms-marco-MiniLM&lt;br&gt;Top 60 candidates&lt;br&gt;Blend: 0.4×RRF + 0.6×CE&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontFamily=Inter;fontSize=12;arcSize=12;" vertex="1" parent="query_container">
