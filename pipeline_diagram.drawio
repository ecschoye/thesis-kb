          <mxGeometry x="1060" y="230" width="140" height="55" as="geometry" />
        </mxCell>

        <!-- ── Step 7: Selection ── -->
        <mxCell id="selection" value="&lt;b&gt;7. Select&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Type-balanced&lt;br&gt;Paper-diverse&lt;br&gt;max 2–4 per paper&lt;br&gt;→ 16 nuggets&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontFamily=Inter;fontSize=12;arcSize=12;" vertex="1" parent="query_container">
          <mxGeometry x="1250" y="90" width="140" height="110" as="geometry" />
